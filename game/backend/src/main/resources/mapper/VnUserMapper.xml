<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.visualnovel.repository.VnUserMapper">

    <resultMap id="userResultMap" type="VnUser">
        <id     property="userId"    column="user_id"/>
        <result property="userType"  column="user_type"/>
        <result property="userName"  column="user_name"/>
        <result property="createdAt" column="created_at"/>
        <result property="lastLogin" column="last_login"/>
    </resultMap>

    <!-- 유저 조회 (ID) -->
    <select id="selectById" parameterType="String" resultMap="userResultMap">
        SELECT * FROM vn_user WHERE user_id = #{userId}
    </select>

    <!-- 유저 조회 (이름) -->
    <select id="selectByName" parameterType="String" resultMap="userResultMap">
        SELECT * FROM vn_user WHERE user_name = #{userName} AND user_type = 'NAMED'
    </select>

    <!-- 유저 등록 -->
    <insert id="insertUser" parameterType="VnUser">
        INSERT INTO vn_user (user_id, user_type, user_name, created_at, last_login)
        VALUES (#{userId}, #{userType}, #{userName}, NOW(), NOW())
    </insert>

    <!-- 마지막 로그인 갱신 -->
    <update id="updateLastLogin" parameterType="String">
        UPDATE vn_user SET last_login = NOW() WHERE user_id = #{userId}
    </update>

</mapper>
